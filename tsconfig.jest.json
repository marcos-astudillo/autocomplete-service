{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "jest"],
    "rootDir": ".",
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "tests/unit/**/*",
    "tests/setup.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests/integration/**/*",
    "tests/load/**/*",
    "docs"
  ]
}
